<section class="profile-section">
    <div class="container">
        <h1>Ho So Ca Nhan</h1>

        <% 
            var successMsg = '';
            var errorMsg = '';
            if (typeof success !== 'undefined' && success) { successMsg = success; }
            if (typeof error !== 'undefined' && error) { errorMsg = error; }
        %>
        <% if (successMsg) { %>
            <div class="alert alert-success"><%= successMsg %></div>
        <% } %>
        <% if (errorMsg) { %>
            <div class="alert alert-error"><%= errorMsg %></div>
        <% } %>

        <div class="profile-grid">
            <!-- Left column: account info + change password -->
            <div class="profile-sidebar">
                <div class="profile-card">
                    <div class="profile-avatar">
                        <span><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></span>
                    </div>
                    <h2><%= user.name %></h2>
                    <p class="profile-email"><%= user.email %></p>
                    <div class="profile-meta">
                        <div class="meta-item">
                            <span class="meta-label">Dien thoai</span>
                            <span class="meta-value"><%= user.phone || 'Chua cap nhat' %></span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Dia chi</span>
                            <span class="meta-value"><%= user.address || 'Chua cap nhat' %></span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Ngay tao</span>
                            <span class="meta-value"><%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></span>
                        </div>
                    </div>
                </div>

                <!-- Change password form -->
                <div class="profile-card">
                    <h3>Doi Mat Khau</h3>
                    <form method="POST" action="/user/change-password" class="change-password-form">
                        <div class="form-group">
                            <label for="currentPassword">Mat khau hien tai</label>
                            <input type="password" id="currentPassword" name="currentPassword" placeholder="Nhap mat khau hien tai" required>
                        </div>
                        <div class="form-group">
                            <label for="newPassword">Mat khau moi</label>
                            <input type="password" id="newPassword" name="newPassword" placeholder="It nhat 6 ky tu" minlength="6" required>
                        </div>
                        <div class="form-group">
                            <label for="confirmPassword">Xac nhan mat khau moi</label>
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Nhap lai mat khau moi" minlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">Doi Mat Khau</button>
                    </form>
                </div>

                <!-- Edit profile form -->
                <div class="profile-card">
                    <h3>Chinh Sua Ho So</h3>
                    <form method="POST" action="/user/update-profile" class="change-password-form">
                        <div class="form-group">
                            <label for="editName">Ho ten</label>
                            <input type="text" id="editName" name="name" value="<%= user.name %>" required>
                        </div>
                        <div class="form-group">
                            <label for="editEmail">Email</label>
                            <input type="email" id="editEmail" name="email" value="<%= user.email %>" required>
                        </div>
                        <div class="form-group">
                            <label for="editPhone">So dien thoai</label>
                            <input type="tel" id="editPhone" name="phone" value="<%= user.phone || '' %>" placeholder="Nhap so dien thoai">
                        </div>
                        <div class="form-group">
                            <label for="editAddress">Dia chi</label>
                            <input type="text" id="editAddress" name="address" value="<%= user.address || '' %>" placeholder="Nhap dia chi">
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">Luu Thay Doi</button>
                    </form>
                </div>

                <!-- Reception: branch change request -->
                <% if (user.role === 'reception') { %>
                <div class="profile-card">
                    <h3>Thong Tin Chi Nhanh Le Tan</h3>
                    <div class="profile-meta" style="margin-bottom:16px;">
                        <div class="meta-item">
                            <span class="meta-label">Chi nhanh hien tai</span>
                            <span class="meta-value" style="color:<%= user.branchId ? '#2e7d32' : '#e65100' %>;font-weight:600;">
                                <%= user.branchId ? user.branchId.name : 'Chua duoc gan chi nhanh' %>
                            </span>
                        </div>
                        <% if (user.branchId && user.branchId.address) { %>
                        <div class="meta-item">
                            <span class="meta-label">Dia chi</span>
                            <span class="meta-value"><%= user.branchId.address %></span>
                        </div>
                        <% } %>
                        <div class="meta-item">
                            <span class="meta-label">Trang thai yeu cau</span>
                            <span class="meta-value">
                                <% if (user.branchChangeStatus === 'pending') { %>
                                    <span style="background:#fff3e0;color:#e65100;padding:2px 10px;border-radius:10px;font-size:0.78rem;font-weight:600;">Dang cho duyet</span>
                                <% } else if (user.branchChangeStatus === 'approved') { %>
                                    <span style="background:#e8f5e9;color:#2e7d32;padding:2px 10px;border-radius:10px;font-size:0.78rem;font-weight:600;">Da duyet</span>
                                <% } else if (user.branchChangeStatus === 'rejected') { %>
                                    <span style="background:#fce4ec;color:#c2185b;padding:2px 10px;border-radius:10px;font-size:0.78rem;font-weight:600;">Bi tu choi</span>
                                <% } else { %>
                                    <span style="background:#f5f5f5;color:#888;padding:2px 10px;border-radius:10px;font-size:0.78rem;font-weight:600;">Khong co yeu cau</span>
                                <% } %>
                            </span>
                        </div>
                        <% if (user.branchChangeStatus === 'pending' && user.pendingBranchId) { %>
                        <div class="meta-item">
                            <span class="meta-label">Dang yeu cau</span>
                            <span class="meta-value"><%= user.pendingBranchId.name %></span>
                        </div>
                        <% } %>
                    </div>

                    <% if (user.branchChangeStatus !== 'pending') { %>
                    <form method="POST" action="/user/request-branch-change" class="change-password-form">
                        <div class="form-group">
                            <label for="newBranchId">Yeu cau doi chi nhanh</label>
                            <select id="newBranchId" name="newBranchId" required style="width:100%;padding:10px 12px;border:1px solid #e0d8ce;border-radius:6px;font-size:0.9rem;box-sizing:border-box;">
                                <option value="">-- Chon chi nhanh moi --</option>
                                <% if (typeof branches !== 'undefined' && branches) { %>
                                    <% branches.forEach(function(b) { %>
                                        <option value="<%= b._id %>"><%= b.name %><%= b.address ? ' — ' + b.address : '' %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">Gui Yeu Cau</button>
                    </form>
                    <% } else { %>
                    <p style="font-size:0.85rem;color:#888;text-align:center;padding:8px 0;">Yeu cau dang duoc admin xem xet. Vui long cho.</p>
                    <% } %>
                </div>
                <% } %>

            </div>

            <!-- Right column: activity history -->
            <div class="profile-main">
                <!-- Reservations with ratings -->
                <div class="profile-card">
                    <div class="card-header-row">
                        <h3>Lich Su Dat Ban (<%= reservations ? reservations.length : 0 %>)</h3>
                        <a href="/user/reservation" class="btn btn-small">Dat Ban Moi</a>
                    </div>
                    <% if (reservations && reservations.length > 0) { %>
                        <div class="activity-list">
                            <% reservations.forEach(function(r) { %>
                            <div class="activity-item-card">
                                <div class="activity-item-header">
                                    <div class="activity-icon reservation-icon">R</div>
                                    <div class="activity-content">
                                        <div class="activity-title"><%= r.branchId ? r.branchId.name : 'N/A' %></div>
                                        <div class="activity-details">
                                            <span><%= new Date(r.date).toLocaleDateString('vi-VN') %> luc <%= r.time %></span>
                                            <span><%= r.guests %> khach</span>
                                            <% if (r.totalAmount) { %>
                                            <span><%= r.totalAmount.toLocaleString('vi-VN') %>d</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="activity-status">
                                        <span class="status-tag status-<%= r.status %>"><%= r.status %></span>
                                        <% if (r.paymentStatus === 'unpaid' && r.status !== 'cancelled') { %>
                                            <a href="/user/payment/reservation/<%= r._id %>" class="btn btn-small">Thanh toan</a>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- Staff info if assigned -->
                                <% if (r.staffId) { %>
                                <div class="handler-info-row">
                                    <span class="handler-label">Nhan vien phuc vu:</span>
                                    <span class="handler-name"><%= r.staffId.name %></span>
                                    <% if (r.staffId.phone) { %>
                                    <span class="handler-phone">- <%= r.staffId.phone %></span>
                                    <% } %>
                                </div>
                                <% } %>
                                
                                <!-- Rating section -->
                                <% if (r.status === 'completed') { %>
                                    <% if (r.rating) { %>
                                    <div class="rating-display">
                                        <div class="rating-stars-small">
                                            <% for (var i = 1; i <= 5; i++) { %>
                                            <span class="star-small <%= i <= r.rating ? 'filled' : '' %>">&#9733;</span>
                                            <% } %>
                                            <span class="rating-value"><%= r.rating %>/5</span>
                                        </div>
                                        <% if (r.ratingComment) { %>
                                        <p class="rating-comment-text">"<%= r.ratingComment %>"</p>
                                        <% } %>
                                    </div>
                                    <% } else { %>
                                    <div class="rating-form-inline">
                                        <form method="POST" action="/user/reservations/<%= r._id %>/rate" class="inline-rating-form">
                                            <div class="star-rating-inline" data-id="res-<%= r._id %>">
                                                <input type="hidden" name="rating" id="rating-res-<%= r._id %>" value="">
                                                <% for (var s = 1; s <= 5; s++) { %>
                                                <span class="star-btn-inline" data-target="res-<%= r._id %>" data-value="<%= s %>">&#9733;</span>
                                                <% } %>
                                            </div>
                                            <input type="text" name="ratingComment" placeholder="Nhan xet (tuy chon)..." class="rating-comment-input" maxlength="200">
                                            <button type="submit" class="btn btn-small btn-rate" id="btn-res-<%= r._id %>" disabled>Gui</button>
                                        </form>
                                    </div>
                                    <% } %>
                                <% } %>
                            </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <p>Chua co dat ban nao</p>
                        </div>
                    <% } %>
                </div>

                <!-- Orders with ratings -->
                <div class="profile-card">
                    <div class="card-header-row">
                        <h3>Lich Su Don Hang (<%= orders ? orders.length : 0 %>)</h3>
                        <a href="/user/orders" class="btn btn-small btn-secondary">Xem tat ca</a>
                    </div>
                    <% if (orders && orders.length > 0) { %>
                        <div class="activity-list">
                            <% orders.slice(0, 5).forEach(function(order) { %>
                            <div class="activity-item-card">
                                <div class="activity-item-header">
                                    <div class="activity-icon order-icon">
                                        <% if (order.orderType === 'dine-in') { %>D<% } else { %>T<% } %>
                                    </div>
                                    <div class="activity-content">
                                        <div class="activity-title">
                                            #<%= order._id.toString().slice(-6).toUpperCase() %>
                                            <% if (order.orderType === 'dine-in') { %>
                                                <span class="type-label">An tai quan</span>
                                            <% } else { %>
                                                <span class="type-label takeaway">Mang ve</span>
                                            <% } %>
                                        </div>
                                        <div class="activity-details">
                                            <span><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></span>
                                            <span><%= order.items ? order.items.length : 0 %> mon</span>
                                            <span class="price-highlight"><%= order.finalPrice ? order.finalPrice.toLocaleString('vi-VN') : order.totalPrice.toLocaleString('vi-VN') %>d</span>
                                        </div>
                                    </div>
                                    <div class="activity-status">
                                        <span class="status-tag status-<%= order.status %>"><%= order.status %></span>
                                        <% if (order.paymentStatus === 'unpaid' && order.paymentTiming === 'prepaid' && order.status !== 'cancelled') { %>
                                            <a href="/user/payment/order/<%= order._id %>" class="btn btn-small">Thanh toan</a>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- Handler info -->
                                <% if (order.shipperId || order.staffId) { %>
                                <div class="handler-info-row">
                                    <span class="handler-label"><%= order.shipperId ? 'Shipper:' : 'Nhan vien:' %></span>
                                    <span class="handler-name"><%= (order.shipperId || order.staffId).name %></span>
                                    <% if ((order.shipperId || order.staffId).phone) { %>
                                    <span class="handler-phone">- <%= (order.shipperId || order.staffId).phone %></span>
                                    <% } %>
                                </div>
                                <% } %>
                                
                                <!-- Rating display -->
                                <% if ((order.status === 'completed' || order.status === 'delivered') && order.rating) { %>
                                <div class="rating-display">
                                    <div class="rating-stars-small">
                                        <% for (var i = 1; i <= 5; i++) { %>
                                        <span class="star-small <%= i <= order.rating ? 'filled' : '' %>">&#9733;</span>
                                        <% } %>
                                        <span class="rating-value"><%= order.rating %>/5</span>
                                    </div>
                                    <% if (order.ratingComment) { %>
                                    <p class="rating-comment-text">"<%= order.ratingComment %>"</p>
                                    <% } %>
                                </div>
                                <% } %>
                            </div>
                            <% }); %>
                        </div>
                        <% if (orders.length > 5) { %>
                        <div class="view-more-link">
                            <a href="/user/orders">Xem tat ca <%= orders.length %> don hang</a>
                        </div>
                        <% } %>
                    <% } else { %>
                        <div class="empty-state">
                            <p>Chua co don hang nao</p>
                            <a href="/menu" class="btn btn-primary btn-small">Dat Mon Ngay</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.profile-section {
    padding: 40px 0;
    background: #f8f6f3;
    min-height: 80vh;
}

.profile-section h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 24px;
    color: #2c2c2c;
}

.profile-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 24px;
    align-items: start;
}

.profile-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    margin-bottom: 20px;
}

.profile-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #2c2c2c;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid #f0ebe4;
}

.profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B6F47 0%, #6d563a 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
    margin: 0 auto 12px;
}

.profile-sidebar h2 {
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #2c2c2c;
    margin-bottom: 4px;
}

.profile-email {
    text-align: center;
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 20px;
}

.profile-meta {
    border-top: 1px solid #f0ebe4;
    padding-top: 16px;
}

.meta-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 0.9rem;
}

.meta-label { color: #888; }
.meta-value { color: #333; font-weight: 500; }

/* Change password form */
.change-password-form .form-group {
    margin-bottom: 14px;
}

.change-password-form label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 4px;
}

.change-password-form input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #e0d8ce;
    border-radius: 6px;
    font-size: 0.9rem;
    box-sizing: border-box;
}

.change-password-form input:focus {
    outline: none;
    border-color: #8B6F47;
    box-shadow: 0 0 0 2px rgba(139,111,71,0.1);
}

.btn-block {
    display: block;
    width: 100%;
    text-align: center;
}

/* Activity list */
.card-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid #f0ebe4;
}

.card-header-row h3 {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
}

.activity-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.activity-item-card {
    background: #faf8f5;
    border-radius: 10px;
    padding: 16px;
    transition: all 0.2s;
    border: 1px solid transparent;
}

.activity-item-card:hover {
    background: #f5f0e8;
    border-color: #e0d8ce;
}

.activity-item-header {
    display: flex;
    align-items: center;
    gap: 14px;
}

.activity-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
}

.reservation-icon {
    background: #e8f0fe;
    color: #1a73e8;
}

.order-icon {
    background: #fef3e0;
    color: #e65100;
}

.activity-content {
    flex: 1;
    min-width: 0;
}

.activity-title {
    font-weight: 600;
    color: #2c2c2c;
    font-size: 0.95rem;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.type-label {
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 10px;
    background: #e8f0fe;
    color: #1a73e8;
    font-weight: 600;
}

.type-label.takeaway {
    background: #fff3e0;
    color: #e65100;
}

.activity-details {
    display: flex;
    gap: 12px;
    font-size: 0.82rem;
    color: #888;
}

.price-highlight {
    color: #8B6F47;
    font-weight: 600;
}

.activity-status {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
}

.status-tag {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: capitalize;
}

.status-pending { background: #fff3cd; color: #856404; }
.status-confirmed, .status-approved { background: #d1ecf1; color: #0c5460; }
.status-paid, .status-completed { background: #d4edda; color: #155724; }
.status-cancelled { background: #f8d7da; color: #721c24; }
.status-processing { background: #e8f0fe; color: #1a73e8; }
.status-shipping { background: #fff3e0; color: #e65100; }
.status-delivered { background: #e8f5e9; color: #2e7d32; }

/* Handler info row */
.handler-info-row {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed #e0d8ce;
    font-size: 0.82rem;
    display: flex;
    align-items: center;
    gap: 6px;
}

.handler-label {
    color: #888;
}

.handler-name {
    color: #333;
    font-weight: 600;
}

.handler-phone {
    color: #666;
}

/* Rating display */
.rating-display {
    margin-top: 12px;
    padding: 10px 12px;
    background: #fffbeb;
    border-radius: 8px;
    border-left: 3px solid #eab308;
}

.rating-stars-small {
    display: flex;
    align-items: center;
    gap: 2px;
}

.star-small {
    font-size: 1rem;
    color: #d4d4d8;
}

.star-small.filled {
    color: #eab308;
}

.rating-value {
    margin-left: 8px;
    font-weight: 700;
    font-size: 0.85rem;
    color: #333;
}

.rating-comment-text {
    margin: 6px 0 0;
    font-size: 0.82rem;
    color: #666;
    font-style: italic;
}

/* Rating form inline */
.rating-form-inline {
    margin-top: 12px;
    padding: 12px;
    background: #f5f5f4;
    border-radius: 8px;
    border: 2px dashed #d6d3d1;
}

.inline-rating-form {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.star-rating-inline {
    display: flex;
    gap: 4px;
}

.star-btn-inline {
    font-size: 1.4rem;
    color: #d4d4d8;
    cursor: pointer;
    transition: color 0.15s, transform 0.15s;
    line-height: 1;
}

.star-btn-inline:hover {
    transform: scale(1.15);
}

.star-btn-inline.active {
    color: #eab308;
}

.rating-comment-input {
    flex: 1;
    min-width: 150px;
    padding: 8px 12px;
    border: 1px solid #e0d8ce;
    border-radius: 6px;
    font-size: 0.85rem;
}

.rating-comment-input:focus {
    outline: none;
    border-color: #eab308;
    box-shadow: 0 0 0 2px rgba(234,179,8,0.15);
}

.btn-rate {
    background: #eab308;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-rate:hover:not(:disabled) {
    background: #ca8a04;
}

.btn-rate:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-secondary {
    background: transparent;
    color: #8B6F47;
    border: 1px solid #8B6F47;
}

.btn-secondary:hover {
    background: #8B6F47;
    color: white;
}

.view-more-link {
    margin-top: 16px;
    text-align: center;
    padding-top: 12px;
    border-top: 1px solid #f0ebe4;
}

.view-more-link a {
    color: #8B6F47;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
}

.view-more-link a:hover {
    text-decoration: underline;
}

.empty-state {
    text-align: center;
    padding: 24px;
    color: #999;
}

.empty-state .btn {
    margin-top: 12px;
}

.alert {
    padding: 12px 18px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 0.9rem;
}

.alert-success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.alert-error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}

@media (max-width: 768px) {
    .profile-grid {
        grid-template-columns: 1fr;
    }
    .activity-details {
        flex-wrap: wrap;
        gap: 6px;
    }
    .activity-item-header {
        flex-wrap: wrap;
    }
    .inline-rating-form {
        flex-direction: column;
        align-items: flex-start;
    }
    .rating-comment-input {
        width: 100%;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Star rating functionality for reservations
    document.querySelectorAll('.star-btn-inline').forEach(function(star) {
        star.addEventListener('click', function() {
            var target = this.dataset.target;
            var value = parseInt(this.dataset.value);
            var input = document.getElementById('rating-' + target);
            var btn = document.getElementById('btn-' + target);
            
            input.value = value;
            btn.disabled = false;
            
            var container = this.parentElement;
            container.querySelectorAll('.star-btn-inline').forEach(function(s, idx) {
                if (idx < value) {
                    s.classList.add('active');
                } else {
                    s.classList.remove('active');
                }
            });
        });
        
        star.addEventListener('mouseenter', function() {
            var value = parseInt(this.dataset.value);
            var container = this.parentElement;
            container.querySelectorAll('.star-btn-inline').forEach(function(s, idx) {
                if (idx < value) {
                    s.classList.add('active');
                } else {
                    s.classList.remove('active');
                }
            });
        });
        
        star.addEventListener('mouseleave', function() {
            var target = this.dataset.target;
            var input = document.getElementById('rating-' + target);
            var currentValue = parseInt(input.value) || 0;
            var container = this.parentElement;
            
            container.querySelectorAll('.star-btn-inline').forEach(function(s, idx) {
                if (idx < currentValue) {
                    s.classList.add('active');
                } else {
                    s.classList.remove('active');
                }
            });
        });
    });
});
</script>
