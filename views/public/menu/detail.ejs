<!-- Dish Detail Page - La Maison Restaurant -->

<section class="dish-detail-page" role="main" itemscope itemtype="https://schema.org/Product">
    <div class="container">
        <!-- Breadcrumb Navigation -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Trang Chu</a>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
            <a href="/menu">Thuc Don</a>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
            <span itemprop="name"><%= dish.name %></span>
        </nav>

        <div class="dish-detail-content">
            <!-- Image Gallery Section -->
            <div class="dish-gallery">
                <div class="main-image-wrapper">
                    <% if (dish.discount > 0) { %>
                        <div class="discount-badge">
                            <span>-<%= dish.discount %>%</span>
                        </div>
                    <% } %>
                    <img src="<%= dish.image || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800&h=600&fit=crop' %>" 
                         alt="<%= dish.name %>" 
                         itemprop="image"
                         class="main-dish-image"
                         onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800&h=600&fit=crop'">
                </div>
                
                <!-- Thumbnail Gallery (placeholder for multiple images) -->
                <div class="thumbnail-gallery">
                    <button class="thumbnail active">
                        <img src="<%= dish.image || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=150&fit=crop' %>" 
                             alt="<%= dish.name %> - Hinh 1"
                             onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=150&fit=crop'">
                    </button>
                    <button class="thumbnail">
                        <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=200&h=150&fit=crop" 
                             alt="<%= dish.name %> - Hinh 2">
                    </button>
                    <button class="thumbnail">
                        <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?w=200&h=150&fit=crop" 
                             alt="<%= dish.name %> - Hinh 3">
                    </button>
                </div>
            </div>

            <!-- Dish Information Section -->
            <div class="dish-info-section">
                <!-- Category Badge -->
                <div class="dish-meta">
                    <span class="category-badge" itemprop="category"><%= dish.category %></span>
                    <% if (dish.isPopular) { %>
                        <span class="popular-badge">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                            Mon Noi Bat
                        </span>
                    <% } %>
                </div>

                <!-- Dish Title -->
                <h1 class="dish-title" itemprop="name"><%= dish.name %></h1>

                <!-- Description -->
                <div class="dish-description" itemprop="description">
                    <p><%= dish.description %></p>
                </div>

                <!-- Price Section -->
                <div class="price-section" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                    <meta itemprop="priceCurrency" content="VND">
                    <% 
                        const originalPrice = dish.originalPrice || dish.price;
                        const finalPrice = dish.discount > 0 ? Math.round(originalPrice * (1 - dish.discount / 100)) : dish.price;
                    %>
                    <div class="price-main">
                        <span class="current-price" itemprop="price" content="<%= finalPrice %>">
                            <%= finalPrice.toLocaleString('vi-VN') %>d
                        </span>
                        <% if (dish.discount > 0) { %>
                            <span class="original-price"><%= originalPrice.toLocaleString('vi-VN') %>d</span>
                            <span class="save-badge">Tiet kiem <%= (originalPrice - finalPrice).toLocaleString('vi-VN') %>d</span>
                        <% } %>
                    </div>
                    <link itemprop="availability" href="https://schema.org/InStock">
                </div>

                <!-- Features -->
                <div class="dish-features">
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        <span>Chuan bi trong 15-20 phut</span>
                    </div>
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        <span>Nguyen lieu tuoi moi ngay</span>
                    </div>
                    <div class="feature-item">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                        </svg>
                        <span>Duoc yeu thich nhat</span>
                    </div>
                </div>

                <!-- Add to Cart Form -->
                <% if (isLoggedIn && !isAdmin) { %>
                    <form action="/user/cart/add" method="POST" class="add-to-cart-form">
                        <input type="hidden" name="dishId" value="<%= dish._id %>">
                        
                        <div class="quantity-selector">
                            <label>So luong:</label>
                            <div class="quantity-controls">
                                <button type="button" class="qty-btn minus" onclick="changeQuantity(-1)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                    </svg>
                                </button>
                                <input type="number" id="quantity" name="quantity" value="1" min="1" max="99" class="quantity-input">
                                <button type="button" class="qty-btn plus" onclick="changeQuantity(1)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19"/>
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <button type="submit" class="btn btn-primary btn-add-cart">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="9" cy="21" r="1"/>
                                    <circle cx="20" cy="21" r="1"/>
                                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
                                </svg>
                                <span>Them Vao Gio Hang</span>
                            </button>
                            <button type="button" class="btn btn-outline btn-wishlist" title="Them vao yeu thich">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                                </svg>
                            </button>
                        </div>
                    </form>
                <% } else if (!isLoggedIn) { %>
                    <div class="login-prompt">
                        <p>Dang nhap de dat mon va tan huong uu dai thanh vien</p>
                        <a href="/login" class="btn btn-primary">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/>
                                <polyline points="10 17 15 12 10 7"/>
                                <line x1="15" y1="12" x2="3" y2="12"/>
                            </svg>
                            <span>Dang Nhap De Dat Mon</span>
                        </a>
                    </div>
                <% } %>

                <!-- Additional Info -->
                <div class="additional-info">
                    <div class="info-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="3" width="15" height="13"/>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                            <circle cx="5.5" cy="18.5" r="2.5"/>
                            <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                        <span>Giao hang nhanh trong 30 phut</span>
                    </div>
                    <div class="info-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span>Co mat tai tat ca chi nhanh</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Dishes Section -->
        <section class="related-dishes" aria-labelledby="related-heading">
            <h2 id="related-heading">Co The Ban Se Thich</h2>
            <div class="related-grid">
                <div class="related-placeholder">
                    <p>Cac mon an lien quan se duoc hien thi o day</p>
                </div>
            </div>
        </section>
    </div>
</section>

<style>
/* Dish Detail Page Styles */
.dish-detail-page {
    padding: 32px 0 80px;
    background: #f8f6f3;
    min-height: 100vh;
}

.dish-detail-page .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Breadcrumb */
.breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    font-size: 0.875rem;
    flex-wrap: wrap;
}

.breadcrumb a {
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s;
}

.breadcrumb a:hover {
    color: #8B6F47;
}

.breadcrumb svg {
    color: #d1d5db;
    flex-shrink: 0;
}

.breadcrumb > span {
    color: #1f2937;
    font-weight: 500;
}

/* Main Content Grid */
.dish-detail-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 80px;
}

/* Image Gallery */
.dish-gallery {
    position: sticky;
    top: 32px;
}

.main-image-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: white;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.main-dish-image {
    width: 100%;
    height: 450px;
    object-fit: cover;
    display: block;
}

.discount-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    color: white;
    padding: 10px 16px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
}

.thumbnail-gallery {
    display: flex;
    gap: 12px;
    margin-top: 16px;
}

.thumbnail {
    width: 80px;
    height: 60px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
    background: none;
}

.thumbnail.active {
    border-color: #8B6F47;
}

.thumbnail:hover {
    border-color: #c9a86c;
}

.thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Dish Info Section */
.dish-info-section {
    padding: 8px 0;
}

.dish-meta {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}

.category-badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    background: rgba(139, 111, 71, 0.1);
    color: #8B6F47;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.popular-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.dish-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 16px 0;
    font-family: 'Playfair Display', serif;
    line-height: 1.2;
}

/* Description */
.dish-description {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid #e5e7eb;
}

.dish-description p {
    font-size: 1.05rem;
    color: #4b5563;
    line-height: 1.8;
    margin: 0;
}

/* Price Section */
.price-section {
    margin-bottom: 28px;
}

.price-main {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
}

.current-price {
    font-size: 2.25rem;
    font-weight: 700;
    color: #8B6F47;
    font-family: 'Playfair Display', serif;
}

.original-price {
    font-size: 1.25rem;
    color: #9ca3af;
    text-decoration: line-through;
}

.save-badge {
    padding: 6px 12px;
    background: #fef2f2;
    color: #dc2626;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
}

/* Features */
.dish-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
    padding: 20px;
    background: #f9fafb;
    border-radius: 12px;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: #4b5563;
}

.feature-item svg {
    color: #8B6F47;
    flex-shrink: 0;
}

/* Add to Cart Form */
.add-to-cart-form {
    margin-bottom: 28px;
}

.quantity-selector {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
}

.quantity-selector label {
    font-size: 0.95rem;
    font-weight: 600;
    color: #374151;
}

.quantity-controls {
    display: flex;
    align-items: center;
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
}

.qty-btn {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    transition: all 0.2s;
}

.qty-btn:hover {
    background: #f3f4f6;
    color: #8B6F47;
}

.quantity-input {
    width: 60px;
    height: 44px;
    border: none;
    border-left: 1px solid #e5e7eb;
    border-right: 1px solid #e5e7eb;
    text-align: center;
    font-size: 1.1rem;
    font-weight: 600;
}

.quantity-input:focus {
    outline: none;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 12px;
}

.btn-add-cart {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 28px;
    background: linear-gradient(135deg, #8B6F47 0%, #6d563a 100%);
    color: white;
    border: none;
    border-radius: 14px;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-add-cart:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(139, 111, 71, 0.3);
}

.btn-wishlist {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #e5e7eb;
    border-radius: 14px;
    background: white;
    color: #9ca3af;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-wishlist:hover {
    border-color: #ef4444;
    color: #ef4444;
    background: #fef2f2;
}

/* Login Prompt */
.login-prompt {
    padding: 28px;
    background: linear-gradient(135deg, rgba(139, 111, 71, 0.08) 0%, rgba(139, 111, 71, 0.04) 100%);
    border-radius: 16px;
    text-align: center;
    margin-bottom: 28px;
}

.login-prompt p {
    font-size: 0.95rem;
    color: #4b5563;
    margin: 0 0 16px 0;
}

.login-prompt .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #8B6F47 0%, #6d563a 100%);
    color: white;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
}

.login-prompt .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(139, 111, 71, 0.3);
}

/* Additional Info */
.additional-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid #e5e7eb;
}

.info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: #6b7280;
}

.info-item svg {
    color: #8B6F47;
}

/* Related Dishes */
.related-dishes {
    padding-top: 60px;
    border-top: 1px solid #e5e7eb;
}

.related-dishes h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 32px 0;
    font-family: 'Playfair Display', serif;
}

.related-placeholder {
    padding: 60px;
    background: white;
    border-radius: 16px;
    text-align: center;
    color: #9ca3af;
}

/* Responsive Design */
@media (max-width: 1024px) {
    .dish-detail-content {
        gap: 32px;
    }
    
    .dish-title {
        font-size: 2rem;
    }
}

@media (max-width: 768px) {
    .dish-detail-page {
        padding: 20px 0 60px;
    }
    
    .dish-detail-content {
        grid-template-columns: 1fr;
        gap: 24px;
    }
    
    .dish-gallery {
        position: static;
    }
    
    .main-dish-image {
        height: 300px;
    }
    
    .dish-title {
        font-size: 1.75rem;
    }
    
    .current-price {
        font-size: 1.75rem;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .btn-wishlist {
        width: 100%;
        height: 50px;
    }
}
</style>

<script>
function changeQuantity(delta) {
    const input = document.getElementById('quantity');
    let value = parseInt(input.value) + delta;
    if (value < 1) value = 1;
    if (value > 99) value = 99;
    input.value = value;
}

// Thumbnail gallery functionality
document.addEventListener('DOMContentLoaded', function() {
    const thumbnails = document.querySelectorAll('.thumbnail');
    const mainImage = document.querySelector('.main-dish-image');
    
    thumbnails.forEach(thumb => {
        thumb.addEventListener('click', function() {
            thumbnails.forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            const newSrc = this.querySelector('img').src.replace('w=200&h=150', 'w=800&h=600');
            mainImage.src = newSrc;
        });
    });
});
</script>
