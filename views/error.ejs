<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loi He Thong - La Maison</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { margin: 0; font-family: 'Inter', sans-serif; background: #f8f6f3; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .error-page { text-align: center; padding: 40px 20px; max-width: 500px; }
        .error-page h1 { font-family: 'Playfair Display', serif; font-size: 2rem; color: #3e3328; margin-bottom: 12px; }
        .error-page .error-message { color: #888; font-size: 0.95rem; margin-bottom: 24px; line-height: 1.5; word-break: break-word; }
        .error-page .btn { display: inline-block; padding: 12px 28px; background: #8B6F47; color: #fff; text-decoration: none; border-radius: 8px; font-weight: 500; transition: background 0.2s; }
        .error-page .btn:hover { background: #6d5636; }
        .error-page .links { margin-top: 16px; }
        .error-page .links a { color: #8B6F47; text-decoration: none; font-size: 0.88rem; margin: 0 10px; }
        .error-page .links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="error-page">
        <h1>Loi He Thong</h1>
        <p class="error-message"><%= typeof error !== 'undefined' ? error : 'Da xay ra loi khong xac dinh.' %></p>
        <a href="/" class="btn">Quay Lai Trang Chu</a>
        <div class="links">
            <a href="javascript:history.back()">Quay lai trang truoc</a>
        </div>
    </div>
</body>
</html>
