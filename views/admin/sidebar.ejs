          <span>Don Hang</span>
        </a></li>
        <li><a href="/admin/reservations" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'reservations') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/></svg>
          <span>Dat Ban</span>
        </a></li>
        <li><a href="/admin/revenue" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'revenue') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          <span>Doanh Thu</span>
        </a></li>
        <li><a href="/admin/reviews" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'reviews') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span>Danh Gia</span>
        </a></li>
      </ul>
    </div>

    <!-- Product & Venue Management -->
    <div class="nav-section">
      <h3 class="nav-section-title">San Pham</h3>
      <ul class="nav-list">
        <li><a href="/admin/dishes" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'dishes') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/></svg>
          <span>Mon An</span>
        </a></li>
        <li><a href="/admin/branches" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'branches') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          <span>Chi Nhanh</span>
        </a></li>
        <li><a href="/admin/events" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'events') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg>
          <span>Su Kien</span>
        </a></li>
      </ul>
    </div>

    <!-- Staff & User Management -->
    <div class="nav-section">
      <h3 class="nav-section-title">Nhan Su</h3>
      <ul class="nav-list">
        <li><a href="/admin/users" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'users') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <span>Nguoi Dung</span>
        </a></li>
        <li><a href="/admin/contacts" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'contacts') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          <span>Phan Hoi</span>
        </a></li>
      </ul>
    </div>

    <!-- Content Management -->
    <div class="nav-section">
      <h3 class="nav-section-title">Noi Dung</h3>
      <ul class="nav-list">
        <li><a href="/admin/blogs" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'blogs') ? 'active' : '' %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
          <span>Blog</span>
        </a></li>
      </ul>
    </div>
  </nav>

  <!-- Sidebar Footer with Logout -->
  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div class="user-details">
        <span class="user-name"><%= typeof user !== 'undefined' && user ? user.name : 'Admin' %></span>
        <span class="user-role">Quan tri vien</span>
      </div>
    </div>
    <a href="/logout" class="logout-btn" title="Dang Xuat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <span>Dang Xuat</span>
    </a>
  </div>

  <style>
    /* Admin sidebar - Only shown on admin pages */
    .admin-sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: 280px;
      height: 100vh;
      background: linear-gradient(180deg, #2a2a2a 0%, #1f1f1f 100%);
      color: #fff;
      padding: 20px 0 0 0;
      z-index: 1100;
      overflow-y: auto;
      overflow-x: hidden;
      box-shadow: 3px 0 12px rgba(0, 0, 0, 0.3);
      scrollbar-width: thin;
      scrollbar-color: rgba(139, 111, 71, 0.4) transparent;
      display: none; /* Hidden by default */
      flex-direction: column;
    }
    
    /* Only show sidebar when admin-layout class is present on body */
    body.admin-layout .admin-sidebar {
      display: flex;
    }
    
    /* Hide topbar and navbar on admin pages */
    body.admin-layout .topbar,
    body.admin-layout .navbar,
    body.admin-layout .footer {
      display: none;
    }

    .admin-sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .admin-sidebar::-webkit-scrollbar-track {
      background: transparent;
    }

    .admin-sidebar::-webkit-scrollbar-thumb {
      background: rgba(139, 111, 71, 0.4);
      border-radius: 3px;
    }

    .admin-sidebar::-webkit-scrollbar-thumb:hover {
      background: rgba(139, 111, 71, 0.6);
    }

    .sidebar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 20px;
      margin-bottom: 8px;
      border-bottom: 1px solid rgba(139, 111, 71, 0.2);
      padding-bottom: 12px;
    }

    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand-link {
      width: 36px;
      height: 36px;
      background: rgba(139, 111, 71, 0.2);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #8B6F47;
      transition: all 0.2s;
    }

    .brand-link:hover {
      background: #8B6F47;
      color: white;
    }

    .sidebar-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: #8B6F47;
      margin: 0;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }

    /* Quick Actions */
    .sidebar-quick-actions {
      display: flex;
      gap: 8px;
      padding: 0 20px 16px;
      border-bottom: 1px solid rgba(139, 111, 71, 0.2);
      margin-bottom: 8px;
    }

    .quick-action-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 0.78rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }

    .quick-action-btn.home-btn {
      background: rgba(139, 111, 71, 0.15);
      color: #c9a86c;
    }

    .quick-action-btn.home-btn:hover {
      background: #8B6F47;
      color: white;
    }

    .quick-action-btn.dashboard-btn {
      background: rgba(255, 255, 255, 0.08);
      color: #b8b8b8;
    }

    .quick-action-btn.dashboard-btn:hover {
      background: rgba(255, 255, 255, 0.15);
      color: white;
    }

    /* Sidebar Footer */
    .sidebar-footer {
      margin-top: auto;
      padding: 16px 20px;
      border-top: 1px solid rgba(139, 111, 71, 0.2);
      background: rgba(0, 0, 0, 0.15);
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .user-avatar {
      width: 40px;
      height: 40px;
      background: rgba(139, 111, 71, 0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #c9a86c;
    }

    .user-details {
      flex: 1;
      min-width: 0;
    }

    .user-name {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: #fff;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .user-role {
      display: block;
      font-size: 0.72rem;
      color: #888;
    }

    .logout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 12px;
      background: rgba(198, 40, 40, 0.15);
      color: #ef5350;
      border: 1px solid rgba(198, 40, 40, 0.3);
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }

    .logout-btn:hover {
      background: #c62828;
      color: white;
      border-color: #c62828;
    }

    .sidebar-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      flex-direction: column;
      gap: 5px;
      padding: 8px;
    }

    .sidebar-toggle span {
      width: 20px;
      height: 2px;
      background: #8B6F47;
      border-radius: 1px;
      transition: all 0.3s;
    }

    .admin-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
      overflow-y: auto;
    }

    .nav-section {
      padding: 0;
      margin-bottom: 0;
    }

    .nav-section-title {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: #8B6F47;
      padding: 14px 20px 10px;
      margin: 0;
      border-top: 1px solid rgba(139, 111, 71, 0.3);
      margin-top: 12px;
    }

    .nav-section:first-child .nav-section-title {
      border-top: none;
      margin-top: 0;
      padding-top: 0;
    }

    .nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .nav-list li {
      margin: 0;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 20px;
      color: #b8b8b8;
      text-decoration: none;
      transition: all 0.2s ease;
      border-left: 3px solid transparent;
      font-size: 0.88rem;
      font-weight: 500;
    }

    .nav-item:hover {
      background: rgba(139, 111, 71, 0.12);
      color: #e0e0e0;
      border-left-color: #8B6F47;
    }

    .nav-item.active {
      background: rgba(139, 111, 71, 0.25);
      color: #fff;
      border-left-color: #8B6F47;
      font-weight: 600;
    }

    .nav-item svg {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      stroke-width: 2;
      stroke: currentColor;
    }

    /* Main content adjustment - only for admin pages */
    body.admin-layout .main-content {
      margin-left: 280px;
      padding-top: 0;
    }
    
    /* Public pages should not have margin */
    body.public-layout .main-content {
      margin-left: 0;
    }

    /* Mobile responsiveness */
    @media (max-width: 768px) {
      .admin-sidebar {
        width: 260px;
        transform: translateX(-100%);
        transition: transform 0.3s;
      }

      .admin-sidebar.open {
        transform: translateX(0);
      }

      .sidebar-toggle {
        display: flex;
      }

      main {
        margin-left: 0;
      }

      .sidebar-toggle.active span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }

      .sidebar-toggle.active span:nth-child(2) {
        opacity: 0;
      }

      .sidebar-toggle.active span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
    }
  </style>

  <script>
    (function() {
      var toggle = document.getElementById('sidebarToggle');
      var sidebar = document.querySelector('.admin-sidebar');
      
      if (toggle && sidebar) {
        toggle.addEventListener('click', function() {
          toggle.classList.toggle('active');
          sidebar.classList.toggle('open');
        });
        
        // Close on link click
        var links = sidebar.querySelectorAll('.nav-item');
        for (var i = 0; i < links.length; i++) {
          links[i].addEventListener('click', function() {
            if (window.innerWidth <= 768) {
              toggle.classList.remove('active');
              sidebar.classList.remove('open');
            }
          });
        }
      }
    })();
  </script>
</aside>
