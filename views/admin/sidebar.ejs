<!-- Optimized Admin Sidebar Navigation -->
<aside class="admin-sidebar">
  <div class="sidebar-header">
    <div class="sidebar-brand">
      <a href="/" class="brand-link" title="Trang Chu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      <h2 class="sidebar-title">Quan Tri</h2>
    </div>
    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Quick Actions -->
  <div class="sidebar-quick-actions">
    <a href="/" class="quick-action-btn home-btn" title="Trang Chu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Trang Chu</span>
    </a>
    <a href="/admin" class="quick-action-btn dashboard-btn" title="Dashboard">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span>Dashboard</span>
    </a>
  </div>

  <nav class="admin-nav">
    <!-- Business Operations -->
    <div class="nav-section">
      <h3 class="nav-section-title">Kinh Doanh</h3>
      <ul class="nav-list">
        <li><a href="/admin/orders" class="nav-item <%= (typeof currentPage !== 'undefined' && currentPage === 'orders') ? 'active' : '' %>">
