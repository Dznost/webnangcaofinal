<script>
function previewMainImage(url) {
    const preview = document.getElementById('mainImagePreview');
    if (url) {
        preview.innerHTML = '<img src="' + url + '" alt="Preview">';
    }
}

function addImageField() {
    const container = document.getElementById('imagesContainer');
    const div = document.createElement('div');
    div.className = 'gallery-item';
    div.innerHTML = '<div class="gallery-preview"><img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=80&h=60&fit=crop"></div><input type="text" name="images" placeholder="https://example.com/image.jpg" class="field-input" onchange="updateGalleryPreview(this)"><button type="button" class="btn-remove-gallery" onclick="removeImageField(this)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>';
    container.appendChild(div);
}

function removeImageField(btn) {
    btn.closest('.gallery-item').remove();
}

function updateGalleryPreview(input) {
    const preview = input.parentElement.querySelector('.gallery-preview img');
    if (input.value) {
        preview.src = input.value;
    }
}

function filterDishes(search) {
    const items = document.querySelectorAll('.checklist-item');
    search = search.toLowerCase();
    items.forEach(item => {
        const name = item.getAttribute('data-name');
        item.style.display = name.includes(search) ? 'flex' : 'none';
    });
}

// Update table status bar
document.getElementById('totalTables')?.addEventListener('input', updateStatusBar);
document.getElementById('availableTables')?.addEventListener('input', updateStatusBar);

function updateStatusBar() {
    const total = parseInt(document.getElementById('totalTables').value) || 1;
    const available = parseInt(document.getElementById('availableTables').value) || 0;
    const filled = Math.round(((total - available) / total) * 100);
    document.getElementById('filledBar').style.width = filled + '%';
}
</script>
