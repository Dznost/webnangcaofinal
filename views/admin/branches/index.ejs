/* Result Count */
.result-count { text-align: center; color: #888; font-size: 0.85rem; margin-top: 24px; }

/* Empty State */
.empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 16px; border: 2px dashed #e0d8ce; }
