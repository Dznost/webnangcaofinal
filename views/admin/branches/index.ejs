</style>

<script>
function filterBranches(query) {
    var cards = document.querySelectorAll('.branch-admin-card');
    var count = 0;
    var q = query.toLowerCase().trim();
    
    cards.forEach(function(card) {
        var name = card.getAttribute('data-name') || '';
        if (name.indexOf(q) !== -1) {
            card.style.display = '';
            count++;
        } else {
            card.style.display = 'none';
        }
    });
    
    document.getElementById('branchCount').textContent = count + ' chi nhanh';
}

function toggleEmpDetails(branchId) {
    var details = document.getElementById('empDetails_' + branchId);
    var btn = details.previousElementSibling.nextElementSibling;
    
    if (details.classList.contains('show')) {
        details.classList.remove('show');
        btn.classList.remove('open');
        btn.querySelector('.toggle-text').textContent = 'Xem chi tiet';
    } else {
        details.classList.add('show');
        btn.classList.add('open');
        btn.querySelector('.toggle-text').textContent = 'An bot';
    }
}

function toggleBranchChart(branchId) {
    var chart = document.getElementById('branchChart_' + branchId);
    if (chart.classList.contains('show')) {
        chart.classList.remove('show');
    } else {
        // Close all other charts first
        document.querySelectorAll('.branch-chart-panel').forEach(function(c) {
            c.classList.remove('show');
        });
        chart.classList.add('show');
    }
}

function changeTable(branchId, action) {
    fetch('/admin/branches/' + branchId + '/tables', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: action })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            location.reload();
        } else {
            alert(data.message || 'Co loi xay ra');
        }
    })
    .catch(function(err) {
        console.error('Error:', err);
        alert('Loi ket noi');
    });
}
</script>
