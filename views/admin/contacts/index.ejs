<section class="admin-section">
    <div class="container">
        <div class="section-header">
            <h1>Quan Ly Lien He</h1>
        </div>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <div class="filter-bar">
            <a href="/admin/contacts?type=all" class="filter-btn <%= typeFilter === 'all' ? 'active' : '' %>">Tat Ca Lien He</a>
            <a href="/admin/contacts?type=reviews" class="filter-btn <%= typeFilter === 'reviews' ? 'active' : '' %>">Danh Gia Don Hang</a>
            <a href="/admin/contacts?type=feedback" class="filter-btn <%= typeFilter === 'feedback' ? 'active' : '' %>">Phan Hoi</a>
            <a href="/admin/contacts?type=shipper" class="filter-btn <%= typeFilter === 'shipper' ? 'active' : '' %>">Don Dang Ky Shipper</a>
            <a href="/admin/contacts?type=staff" class="filter-btn <%= typeFilter === 'staff' ? 'active' : '' %>">Don Dang Ky Nhan Vien</a>
        </div>

        <!-- Order Reviews Section -->
        <% if (typeFilter === 'reviews') { %>
          <% if (typeof orderReviews !== 'undefined' && orderReviews && orderReviews.length > 0) { %>
          <div class="reviews-summary" style="display:flex;gap:16px;margin-bottom:20px;flex-wrap:wrap;">
            <div class="review-stat-card">
              <span class="review-stat-num"><%= orderReviews.length %></span>
              <span class="review-stat-label">Tong danh gia</span>
            </div>
            <div class="review-stat-card">
              <span class="review-stat-num" style="color:#eab308;">
                <% var avgRating = orderReviews.reduce(function(s,r){ return s + (r.rating || 0); }, 0) / orderReviews.length; %>
                <%= avgRating.toFixed(1) %>
              </span>
              <span class="review-stat-label">Trung binh sao</span>
            </div>
            <div class="review-stat-card">
              <span class="review-stat-num" style="color:#2e7d32;"><%= orderReviews.filter(function(r){ return r.rating >= 4; }).length %></span>
              <span class="review-stat-label">Danh gia tot (4-5)</span>
            </div>
            <div class="review-stat-card">
              <span class="review-stat-num" style="color:#c62828;"><%= orderReviews.filter(function(r){ return r.rating <= 2; }).length %></span>
              <span class="review-stat-label">Danh gia thap (1-2)</span>
            </div>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th>Don Hang</th>
                <th>Khach Hang</th>
                <th>Chi Nhanh</th>
                <th>Danh Gia</th>
                <th>Nhan Xet</th>
                <th>Nguoi Xu Ly</th>
                <th>Ngay Danh Gia</th>
                <th>Hanh Dong</th>
              </tr>
            </thead>
            <tbody>
              <% orderReviews.forEach(function(review) { %>
              <tr>
                <td>
                  <a href="/admin/orders/<%= review._id %>" style="color:#8B6F47;font-weight:600;text-decoration:none;">
                    #<%= review._id.toString().slice(-6).toUpperCase() %>
                  </a>
                  <div style="font-size:0.75rem;color:#999;"><%= review.orderType === 'dine-in' ? 'An tai quan' : 'Giao hang' %></div>
                </td>
                <td>
                  <strong style="font-size:0.88rem;"><%= review.userId ? review.userId.name : (review.fullName || 'N/A') %></strong>
                  <div style="font-size:0.75rem;color:#999;"><%= review.userId ? review.userId.email : '' %></div>
                </td>
                <td><%= review.branchId ? review.branchId.name : '-' %></td>
                <td>
                  <div class="star-display-inline">
                    <% for (var si = 1; si <= 5; si++) { %>
                    <span class="star-sm <%= si <= review.rating ? 'filled' : '' %>">&#9733;</span>
                    <% } %>
                    <strong style="margin-left:4px;font-size:0.88rem;"><%= review.rating %>/5</strong>
                  </div>
                </td>
                <td>
                  <% if (review.ratingComment) { %>
                  <div class="review-comment-cell" title="<%= review.ratingComment %>">
                    "<%= review.ratingComment.length > 50 ? review.ratingComment.substring(0, 50) + '...' : review.ratingComment %>"
                  </div>
                  <% } else { %>
                  <span style="color:#ccc;font-style:italic;">Khong co nhan xet</span>
                  <% } %>
                </td>
                <td>
                  <% if (review.shipperId) { %>
                  <span class="type-badge shipper-type"><%= review.shipperId.name %></span>
                  <% } else if (review.staffId) { %>
                  <span class="type-badge staff-type"><%= review.staffId.name %></span>
                  <% } else { %>
                  <span style="color:#ccc;">-</span>
                  <% } %>
                </td>
                <td style="font-size:0.82rem;color:#888;"><%= review.ratedAt ? new Date(review.ratedAt).toLocaleString('vi-VN') : '-' %></td>
                <td>
                  <a href="/admin/orders/<%= review._id %>" class="btn btn-small btn-primary">Xem Don</a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } else { %>
          <div class="empty-message" style="text-align:center;padding:40px;color:#999;">
            <p>Chua co danh gia nao tu khach hang.</p>
          </div>
          <% } %>
        <% } %>

        <!-- Contacts Table -->
        <% if (typeFilter !== 'reviews' && contacts && contacts.length > 0) { %>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Loai</th>
                    <th>Ten</th>
                    <th>Email</th>
                    <th>SDT</th>
                    <th>Tin Nhan</th>
                    <th>Trang Thai</th>
                    <th>Ngay Gui</th>
                    <th>Hanh Dong</th>
                </tr>
            </thead>
            <tbody>
                <% contacts.forEach(contact => { %>
                <tr>
                    <td>
                        <% if (contact.type === 'shipper_application') { %>
                            <span class="type-badge shipper-type">Shipper</span>
                        <% } else if (contact.type === 'staff_application') { %>
                            <span class="type-badge staff-type">Nhan vien</span>
                        <% } else { %>
                            <span class="type-badge feedback-type">Phan hoi</span>
                        <% } %>
                    </td>
                    <td><%= contact.name %></td>
                    <td><%= contact.email %></td>
                    <td><%= contact.phone || '-' %></td>
                    <td><%= contact.message.substring(0, 40) %>...</td>
                    <td>
                        <span class="status-badge status-<%= contact.status %>">
                            <% if (contact.status === 'new') { %>Moi<% } %>
                            <% if (contact.status === 'read') { %>Da Doc<% } %>
                            <% if (contact.status === 'replied') { %>Da Tra Loi<% } %>
                            <% if (contact.status === 'approved') { %>Da Duyet<% } %>
                            <% if (contact.status === 'rejected') { %>Tu Choi<% } %>
                        </span>
                    </td>
                    <td><%= new Date(contact.createdAt).toLocaleDateString('vi-VN') %></td>
                    <td class="action-buttons">
                        <a href="/admin/contacts/<%= contact._id %>" class="btn btn-small btn-primary">Xem</a>
                        <a href="/admin/contacts/<%= contact._id %>/delete" class="btn btn-small btn-danger" onclick="return confirm('Ban chac chan?')">Xoa</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } else if (typeFilter !== 'reviews') { %>
        <p class="empty-message">Chua co lien he nao.</p>
        <% } %>
    </div>
</section>

<style>
.filter-bar { display: flex; gap: 8px; margin-bottom: 20px; }
.filter-btn {
    padding: 8px 18px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;
    text-decoration: none; color: #555; background: white; border: 1px solid #e0d8ce; transition: all 0.2s;
}
.filter-btn:hover { background: #f3efe8; }
.filter-btn.active { background: #8B6F47; color: white; border-color: #8B6F47; }

.type-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 0.78rem; font-weight: 600; }
.shipper-type { background: #fff3e0; color: #e65100; }
.staff-type { background: #e8f5e9; color: #2e7d32; }
.feedback-type { background: #e3f2fd; color: #1565c0; }

.status-approved { background: #d4edda; color: #155724; }
.status-rejected { background: #f8d7da; color: #721c24; }

/* Review stats */
.review-stat-card { background: white; padding: 16px 24px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid #ebe6df; text-align: center; flex: 1; min-width: 120px; }
.review-stat-num { display: block; font-size: 1.5rem; font-weight: 700; color: #3e3328; margin-bottom: 2px; }
.review-stat-label { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.3px; }

/* Star display inline */
.star-display-inline { display: flex; align-items: center; gap: 1px; }
.star-sm { font-size: 1.1rem; color: #e0d8ce; line-height: 1; }
.star-sm.filled { color: #eab308; }

/* Review comment cell */
.review-comment-cell { font-size: 0.82rem; color: #555; font-style: italic; max-width: 200px; line-height: 1.3; }
</style>
