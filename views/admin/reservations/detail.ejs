<style>
  .res-detail { padding: 32px 0; background: #f8f6f3; min-height: 100vh; }
  .res-detail .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
  .back-link { display: inline-flex; align-items: center; gap: 6px; color: #8B6F47; font-size: 0.88rem; text-decoration: none; margin-bottom: 16px; }
  .back-link:hover { text-decoration: underline; }

  /* Header */
  .res-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
  .res-header h1 { font-size: 1.6rem; color: #3e3328; margin: 0; }
  .res-header .badges { display: flex; gap: 10px; flex-wrap: wrap; }
  .res-header .badge { padding: 6px 14px; border-radius: 20px; font-size: 0.82rem; font-weight: 600; }
  .badge-status { background: #fff3e0; color: #e65100; }
  .badge-status.pending { background: #fff3e0; color: #e65100; }
  .badge-status.confirmed { background: #e8f5e9; color: #1b5e20; }
  .badge-status.cancelled { background: #fce4ec; color: #c62828; }
  .badge-status.completed { background: #e8f5e9; color: #1b5e20; }

  .alert { padding: 12px 18px; border-radius: 8px; margin-bottom: 20px; font-size: 0.88rem; }
  .alert-success { background: #e8f5e9; color: #1b5e20; border: 1px solid #c8e6c9; }

  /* Main grid */
  .res-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }
  @media (max-width: 900px) { .res-grid { grid-template-columns: 1fr; } }

  /* Cards */
  .card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border: 1px solid #ebe6df; margin-bottom: 20px; }
  .card h3 { margin: 0 0 16px; font-size: 1rem; color: #3e3328; display: flex; align-items: center; gap: 8px; }
  .card h3 svg { color: #8B6F47; }

  /* Booking info */
  .booking-highlight { background: linear-gradient(135deg, #00695c 0%, #00897b 100%); color: #fff; border-radius: 12px; padding: 24px; margin-bottom: 20px; }
  .booking-highlight .top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .booking-highlight .date-box { text-align: center; background: rgba(255,255,255,0.15); padding: 12px 20px; border-radius: 10px; }
  .booking-highlight .date-box .day { font-size: 2rem; font-weight: 700; line-height: 1; }
  .booking-highlight .date-box .month { font-size: 0.88rem; opacity: 0.9; }
  .booking-highlight .time-box { font-size: 1.8rem; font-weight: 700; }
  .booking-highlight .details { display: flex; gap: 24px; flex-wrap: wrap; }
  .booking-highlight .detail-item { display: flex; align-items: center; gap: 8px; }
  .booking-highlight .detail-item svg { opacity: 0.8; }
  .booking-highlight .detail-item span { font-size: 0.95rem; }

  /* Guest card */
  .guest-card { border-left: 4px solid #8B6F47; }
  .guest-info { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .guest-info .row { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; }
  .guest-info .label { color: #888; min-width: 70px; }
  .guest-info .value { color: #3e3328; font-weight: 500; }
  .guest-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; padding-top: 12px; border-top: 1px solid #f0ebe4; }
  .guest-stats .stat { text-align: center; }
  .guest-stats .stat .num { font-size: 1.2rem; font-weight: 700; color: #8B6F47; }
  .guest-stats .stat .lbl { font-size: 0.72rem; color: #888; text-transform: uppercase; }
  .recent-res { margin-top: 12px; }
  .recent-res h4 { font-size: 0.82rem; color: #888; margin: 0 0 8px; font-weight: 500; }
  .recent-res-item { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f0ebe4; font-size: 0.82rem; }
  .recent-res-item:last-child { border-bottom: none; }
  .recent-res-item a { color: #8B6F47; text-decoration: none; font-weight: 600; }

  /* Branch card */
  .branch-card { border-left: 4px solid #1565c0; }
  .branch-info { display: flex; flex-direction: column; gap: 6px; }
  .branch-info .row { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; }
  .branch-info .label { color: #888; min-width: 70px; }
  .branch-info .value { color: #3e3328; }

  /* Items table */
  .items-table { width: 100%; border-collapse: collapse; }
  .items-table th, .items-table td { padding: 12px; text-align: left; border-bottom: 1px solid #f0ebe4; font-size: 0.88rem; }
  .items-table th { font-weight: 600; color: #888; text-transform: uppercase; font-size: 0.75rem; }
  .items-table td { color: #3e3328; }
  .items-table .total-row td { font-weight: 700; border-top: 2px solid #e0d8ce; }

  /* Special requests */
  .special-box { background: #fffbeb; border-left: 4px solid #ffc107; padding: 16px; border-radius: 8px; }
  .special-box .title { font-weight: 600; color: #b8860b; font-size: 0.88rem; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .special-box .text { color: #5d4e37; font-size: 0.88rem; line-height: 1.5; }

  /* Payment card */
  .payment-card { border-left: 4px solid #2e7d32; }
  .payment-info { display: flex; flex-direction: column; gap: 8px; }
  .payment-info .row { display: flex; justify-content: space-between; font-size: 0.88rem; }
  .payment-info .label { color: #888; }
  .payment-info .value { color: #3e3328; font-weight: 500; }
  .payment-info .value.success { color: #2e7d32; }

  /* Status form */
  .status-card { border: 2px dashed #e0d8ce; background: #faf8f5; }
  .status-card h3 { color: #8B6F47; }
  .status-form { display: flex; gap: 12px; align-items: center; }
  .status-form select { flex: 1; padding: 10px 14px; border: 1px solid #e0d8ce; border-radius: 6px; font-size: 0.88rem; }
  .status-form button { background: #8B6F47; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; font-weight: 600; cursor: pointer; }
  .status-form button:hover { background: #7a5f3a; }
</style>

<section class="res-detail">
  <div class="container">
    <a href="/admin/reservations" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Quay lai danh sach
    </a>

    <div class="res-header">
      <h1>Dat Ban #<%= reservation._id.toString().slice(-6).toUpperCase() %></h1>
      <div class="badges">
        <span class="badge badge-status <%= reservation.status %>">
          <%= reservation.status === 'pending' ? 'Cho xac nhan' :
              reservation.status === 'confirmed' ? 'Da xac nhan' :
              reservation.status === 'completed' ? 'Hoan thanh' : 'Da huy' %>
        </span>
      </div>
    </div>

    <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
    <% } %>

    <!-- Booking highlight -->
    <div class="booking-highlight">
      <div class="top">
        <div class="date-box">
          <div class="day"><%= new Date(reservation.date || reservation.reservationDate).getDate() %></div>
          <div class="month"><%= new Date(reservation.date || reservation.reservationDate).toLocaleDateString('vi-VN', { month: 'short', year: 'numeric' }) %></div>
        </div>
        <div class="time-box"><%= reservation.time || reservation.reservationTime %></div>
      </div>
      <div class="details">
        <div class="detail-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          <span><%= reservation.guests || reservation.numberOfGuests %> khach</span>
        </div>
        <div class="detail-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          <span><%= reservation.branch?.name || 'N/A' %></span>
        </div>
        <% if (reservation.depositAmount > 0) { %>
        <div class="detail-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          <span>Dat coc: <%= reservation.depositAmount.toLocaleString('vi-VN') %>d</span>
        </div>
        <% } %>
      </div>
    </div>

    <div class="res-grid">
      <!-- Left column -->
      <div class="left-col">
        <!-- Items -->
        <% if (reservation.orderItems && reservation.orderItems.length > 0) { %>
        <div class="card">
          <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/></svg>
            Mon An Dat Truoc
          </h3>
          <table class="items-table">
            <thead>
              <tr>
                <th>Mon</th>
                <th>SL</th>
                <th>Gia</th>
                <th>Tong</th>
              </tr>
            </thead>
            <tbody>
              <% reservation.orderItems.forEach(item => { %>
              <tr>
                <td><%= item.dish?.name || 'N/A' %></td>
                <td><%= item.quantity %></td>
                <td><%= (item.price || 0).toLocaleString('vi-VN') %>d</td>
                <td><%= ((item.quantity * item.price) || 0).toLocaleString('vi-VN') %>d</td>
              </tr>
              <% }) %>
              <tr class="total-row">
                <td colspan="3" style="text-align:right;">Tong:</td>
                <td><%= (reservation.totalAmount || 0).toLocaleString('vi-VN') %>d</td>
              </tr>
            </tbody>
          </table>
        </div>
        <% } %>

        <!-- Special requests -->
        <% if (reservation.specialRequests || reservation.notes) { %>
        <div class="special-box">
          <div class="title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Yeu Cau Dac Biet
          </div>
          <div class="text"><%= reservation.specialRequests || reservation.notes %></div>
        </div>
        <% } %>

        <!-- Payment -->
        <% if (payment) { %>
        <div class="card payment-card">
          <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Thanh Toan
          </h3>
          <div class="payment-info">
            <div class="row">
              <span class="label">Trang thai:</span>
              <span class="value <%= payment.status === 'completed' ? 'success' : '' %>"><%= payment.status === 'completed' ? 'Da thanh toan' : 'Cho xac nhan' %></span>
            </div>
            <div class="row">
              <span class="label">Phuong thuc:</span>
              <span class="value"><%= payment.paymentMethod === 'bank' ? 'Chuyen khoan' : 'Tien mat' %></span>
            </div>
            <div class="row">
              <span class="label">Ma GD:</span>
              <span class="value"><%= payment.transactionId || 'N/A' %></span>
            </div>
            <div class="row">
              <span class="label">So tien:</span>
              <span class="value"><%= (payment.finalAmount || payment.amount || 0).toLocaleString('vi-VN') %>d</span>
            </div>
            <% if (payment.paidAt) { %>
            <div class="row">
              <span class="label">Luc:</span>
              <span class="value"><%= new Date(payment.paidAt).toLocaleString('vi-VN') %></span>
            </div>
            <% } %>
          </div>
        </div>
        <% } %>

        <!-- Status update -->
        <div class="card status-card">
          <h3>Cap Nhat Trang Thai</h3>
          <form method="POST" action="/admin/reservations/<%= reservation._id %>/status" class="status-form">
            <select name="status" required>
              <option value="pending" <%= reservation.status === 'pending' ? 'selected' : '' %>>Cho Xac Nhan</option>
              <option value="confirmed" <%= reservation.status === 'confirmed' ? 'selected' : '' %>>Da Xac Nhan</option>
              <option value="cancelled" <%= reservation.status === 'cancelled' ? 'selected' : '' %>>Huy</option>
            </select>
            <button type="submit">Cap Nhat</button>
          </form>
        </div>
      </div>

      <!-- Right column -->
      <div class="right-col">
        <!-- Guest -->
        <div class="card guest-card">
          <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Khach Hang
          </h3>
          <div class="guest-info">
            <div class="row"><span class="label">Ten:</span><span class="value"><%= reservation.user?.name || reservation.guestName || 'N/A' %></span></div>
            <div class="row"><span class="label">Email:</span><span class="value"><%= reservation.user?.email || 'N/A' %></span></div>
            <div class="row"><span class="label">SDT:</span><span class="value"><%= reservation.user?.phone || reservation.phone || 'N/A' %></span></div>
          </div>
          <% if (guestStats) { %>
          <div class="guest-stats">
            <div class="stat">
              <div class="num"><%= guestStats.totalReservations %></div>
              <div class="lbl">Dat ban</div>
            </div>
            <div class="stat">
              <div class="num"><%= guestStats.memberSince ? Math.floor((Date.now() - new Date(guestStats.memberSince)) / (1000 * 60 * 60 * 24)) : 0 %></div>
              <div class="lbl">Ngay</div>
            </div>
          </div>
          <% if (guestStats.recentReservations && guestStats.recentReservations.length > 0) { %>
          <div class="recent-res">
            <h4>Lich su dat ban</h4>
            <% guestStats.recentReservations.forEach(r => { %>
            <div class="recent-res-item">
              <a href="/admin/reservations/<%= r._id %>">#<%= r._id.toString().slice(-6).toUpperCase() %></a>
              <span><%= new Date(r.date).toLocaleDateString('vi-VN') %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
          <% } %>
        </div>

        <!-- Branch -->
        <% if (reservation.branch) { %>
        <div class="card branch-card">
          <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            Chi Nhanh
          </h3>
          <div class="branch-info">
            <div class="row"><span class="label">Ten:</span><span class="value"><%= reservation.branch.name %></span></div>
            <% if (reservation.branch.address) { %>
            <div class="row"><span class="label">Dia chi:</span><span class="value"><%= reservation.branch.address %></span></div>
            <% } %>
            <% if (reservation.branch.phone) { %>
            <div class="row"><span class="label">SDT:</span><span class="value"><%= reservation.branch.phone %></span></div>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
