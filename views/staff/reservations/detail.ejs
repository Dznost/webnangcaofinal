<section class="staff-order-detail">
    <div class="container">
        <div class="page-header">
            <h1>Chi Tiet Dat Ban #<%= reservation._id.toString().slice(-6).toUpperCase() %></h1>
            <a href="/staff/reservations" class="btn btn-secondary btn-small">Quay Lai</a>
        </div>

        <% if (success === 'completed') { %>
        <div class="alert alert-success">Da xac nhan hoan thanh dat ban!</div>
        <% } %>

        <div class="detail-grid">
            <div class="detail-main">
                <div class="detail-card">
                    <h3>Thong Tin Khach Hang</h3>
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Ho ten</span>
                            <span class="info-value"><%= reservation.userId ? reservation.userId.name : 'N/A' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">SDT</span>
                            <span class="info-value"><%= reservation.userId ? reservation.userId.phone : 'N/A' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Chi nhanh</span>
                            <span class="info-value highlight"><%= reservation.branchId ? reservation.branchId.name : 'N/A' %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">So khach</span>
                            <span class="info-value"><%= reservation.guests %> nguoi</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Ngay</span>
                            <span class="info-value"><%= new Date(reservation.date).toLocaleDateString('vi-VN') %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Gio</span>
                            <span class="info-value"><%= reservation.time || 'N/A' %></span>
                        </div>
                        <% if (reservation.specialRequests) { %>
                        <div class="info-item full-width">
                            <span class="info-label">Ghi chu</span>
                            <span class="info-value"><%= reservation.specialRequests %></span>
                        </div>
                        <% } %>
                    </div>
                </div>

                <% if (reservation.orderItems && reservation.orderItems.length > 0) { %>
                <div class="detail-card">
                    <h3>Mon Dat Truoc (<%= reservation.orderItems.length %> mon)</h3>
                    <div class="items-list">
                        <% reservation.orderItems.forEach(function(item) { %>
                        <div class="item-row">
                            <div class="item-info">
                                <span class="item-name"><%= item.name %></span>
                                <span class="item-qty">x<%= item.quantity %></span>
                            </div>
                            <span class="item-price"><%= (item.price * item.quantity).toLocaleString('vi-VN') %>d</span>
                        </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>

            <div class="detail-sidebar">
                <div class="detail-card">
                    <h3>Trang Thai & Thanh Toan</h3>
                    <div class="status-display">
                        <span class="status-tag-lg status-<%= reservation.status %>">
                            <%= reservation.status === 'confirmed' ? 'Da Xac Nhan' : reservation.status === 'paid' ? 'Da Thanh Toan' : reservation.status === 'processing' ? 'Dang Xu Ly' : reservation.status === 'completed' ? 'Hoan Thanh' : reservation.status %>
                        </span>
                    </div>
                    <div class="order-meta">
                        <div class="meta-row">
                            <span>Dat coc</span>
                            <span><%= reservation.depositAmount ? reservation.depositAmount.toLocaleString('vi-VN') : '0' %>d</span>
                        </div>
                        <% if (reservation.foodTotal > 0) { %>
                        <div class="meta-row">
                            <span>Tien mon an</span>
                            <span><%= reservation.foodTotal.toLocaleString('vi-VN') %>d</span>
                        </div>
                        <% } %>
                        <div class="meta-row total-meta">
                            <span>Tong cong</span>
                            <strong><%= reservation.totalAmount ? reservation.totalAmount.toLocaleString('vi-VN') : '0' %>d</strong>
                        </div>
                        <div class="meta-row">
                            <span>Thanh toan</span>
                            <span class="<%= reservation.paymentStatus === 'paid' ? 'text-success' : 'text-warning' %>">
                                <%= reservation.paymentStatus === 'paid' ? 'Da thanh toan' : 'Chua thanh toan' %>
                            </span>
                        </div>
                        <div class="meta-row">
                            <span>Ngay tao</span>
                            <span><%= new Date(reservation.createdAt).toLocaleString('vi-VN') %></span>
                        </div>
                    </div>
                </div>

                <% if (reservation.status !== 'completed' && reservation.status !== 'cancelled') { %>
                <div class="detail-card confirm-card">
                    <h3>Xac Nhan Hoan Thanh</h3>
                    <p class="confirm-note">Xac nhan khi khach hang da su dung dich vu xong va thanh toan day du. Hanh dong nay khong the hoan tac.</p>
                    <button type="button" class="btn btn-success btn-block" id="confirmBtn">
                        Xac Nhan Hoan Thanh
                    </button>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</section>

<% if (reservation.status !== 'completed' && reservation.status !== 'cancelled') { %>
<div class="modal-overlay" id="confirmModal" style="display:none">
    <div class="modal-content">
        <h3>Xac Nhan Hoan Thanh Dat Ban</h3>
        <p>Ban co chac chan khach hang da hoan tat?</p>
        <p class="modal-warning">Hanh dong nay khong the hoan tac.</p>
        <div class="modal-actions">
            <button type="button" class="btn btn-secondary" id="cancelConfirm">Huy</button>
            <form method="POST" action="/staff/reservations/<%= reservation._id %>/confirm-completed" style="display:inline">
                <input type="hidden" name="confirmCode" value="CONFIRMED">
                <button type="submit" class="btn btn-success">Chac Chan Hoan Thanh</button>
            </form>
        </div>
    </div>
</div>
<script>
(function() {
    var btn = document.getElementById('confirmBtn');
    var modal = document.getElementById('confirmModal');
    var cancelBtn = document.getElementById('cancelConfirm');
    if (btn && modal) {
        btn.addEventListener('click', function() { modal.style.display = 'flex'; });
        cancelBtn.addEventListener('click', function() { modal.style.display = 'none'; });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
    }
})();
</script>
<% } %>

<style>
.staff-order-detail { padding: 40px 0; background: #f8f6f3; min-height: 80vh; }
.staff-order-detail h1 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #2c2c2c; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.detail-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }
.detail-card { background: white; border-radius: 10px; padding: 24px; box-shadow: 0 1px 8px rgba(0,0,0,0.06); margin-bottom: 20px; }
.detail-card h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: #2c2c2c; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid #f0ebe4; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.info-item.full-width { grid-column: 1 / -1; }
.info-label { display: block; font-size: 0.8rem; color: #888; margin-bottom: 2px; }
.info-value { display: block; font-size: 0.95rem; color: #333; font-weight: 500; }
.info-value.highlight { color: #8B6F47; font-weight: 600; }
.items-list { margin-bottom: 16px; }
.item-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f0ebe4; }
.item-info { display: flex; align-items: center; gap: 10px; }
.item-name { font-size: 0.9rem; color: #333; }
.item-qty { font-size: 0.82rem; color: #888; background: #f5f0ea; padding: 2px 8px; border-radius: 8px; }
.item-price { font-weight: 600; color: #8B6F47; font-size: 0.9rem; }
.status-display { text-align: center; margin-bottom: 16px; }
.status-tag-lg { display: inline-block; padding: 8px 20px; border-radius: 20px; font-size: 0.9rem; font-weight: 700; }
.status-processing { background: #e3f2fd; color: #1565c0; }
.status-completed { background: #d4edda; color: #155724; }
.status-confirmed { background: #fff3e0; color: #e65100; }
.status-paid { background: #e8f5e9; color: #2e7d32; }
.order-meta { border-top: 1px solid #f0ebe4; padding-top: 12px; }
.meta-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 0.85rem; color: #666; }
.total-meta { border-top: 1px solid #f0ebe4; padding-top: 8px; margin-top: 4px; }
.total-meta strong { color: #8B6F47; }
.text-success { color: #2e7d32; font-weight: 600; }
.text-warning { color: #e65100; font-weight: 600; }
.confirm-card { border: 2px solid #1565c0; }
.confirm-note { font-size: 0.85rem; color: #888; margin-bottom: 16px; line-height: 1.5; }
.btn-success { background: #2e7d32; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }
.btn-success:hover { background: #1b5e20; }
.btn-block { display: block; width: 100%; text-align: center; }
.btn { display: inline-block; padding: 8px 18px; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s; }
.btn-primary { background: #8B6F47; color: white; }
.btn-secondary { background: #e0d8ce; color: #555; }
.btn-small { padding: 6px 14px; font-size: 0.82rem; }
.modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.modal-content { background: white; border-radius: 12px; padding: 32px; max-width: 440px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
.modal-content h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; margin-bottom: 12px; color: #2c2c2c; }
.modal-content p { color: #555; font-size: 0.9rem; margin-bottom: 10px; }
.modal-warning { color: #c62828; font-weight: 600; }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
.alert { padding: 12px 18px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; }
.alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
@media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } .info-grid { grid-template-columns: 1fr; } }
</style>
