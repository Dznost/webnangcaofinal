<div class="container" style="max-width: 900px; margin: 0 auto; padding: 20px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1>Chi Tiet Dat Ban</h1>
    <a href="/reception/reservations" style="color: #8B6F47; text-decoration: none;">← Quay lai</a>
  </div>

  <% if (success) { %>
    <div style="padding: 12px; margin-bottom: 20px; background: #d4edda; color: #155724; border-radius: 4px; border: 1px solid #c3e6cb;">
      Xac nhan dat ban thanh cong!
    </div>
  <% } %>

  <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
    <!-- Reservation Info -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
      <div>
        <h3 style="margin: 0 0 12px 0; color: #3e3328;">Thong Tin Dat Ban</h3>
        <p style="margin: 8px 0;"><strong>Khach Hang:</strong> <%= reservation.userId?.name || '-' %></p>
        <p style="margin: 8px 0;"><strong>Dien Thoai:</strong> <%= reservation.userId?.phone || '-' %></p>
        <p style="margin: 8px 0;"><strong>Email:</strong> <%= reservation.userId?.email || '-' %></p>
        <p style="margin: 8px 0;"><strong>Chi Nhanh:</strong> <%= reservation.branchId?.name || '-' %></p>
      </div>
      <div>
        <h3 style="margin: 0 0 12px 0; color: #3e3328;">Dat Cho</h3>
        <% const resDate = new Date(reservation.date); %>
        <p style="margin: 8px 0;"><strong>Ngay:</strong> <%= resDate.getDate() %>/<%= resDate.getMonth() + 1 %>/<%= resDate.getFullYear() %></p>
        <p style="margin: 8px 0;"><strong>Gio:</strong> <%= reservation.time || '-' %></p>
        <p style="margin: 8px 0;"><strong>So Khach:</strong> <%= reservation.guests %></p>
        <p style="margin: 8px 0;"><strong>Ghi Chu:</strong> <%= reservation.specialRequests || '-' %></p>
      </div>
    </div>

    <!-- Order Items -->
    <div style="margin-bottom: 20px;">
      <h3 style="margin: 0 0 12px 0; color: #3e3328;">Mon Dang Dat</h3>
      <% if (reservation.orderItems && reservation.orderItems.length > 0) { %>
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: #f5f5f5;">
              <th style="padding: 8px; text-align: left; border-bottom: 1px solid #ddd;">Mon An</th>
              <th style="padding: 8px; text-align: center; border-bottom: 1px solid #ddd;">So Luong</th>
              <th style="padding: 8px; text-align: right; border-bottom: 1px solid #ddd;">Gia</th>
            </tr>
          </thead>
          <tbody>
            <% reservation.orderItems.forEach(item => { %>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 8px;"><%= item.dishId?.name || item.name || '-' %></td>
                <td style="padding: 8px; text-align: center;"><%= item.quantity %></td>
                <td style="padding: 8px; text-align: right;"><%= (item.price * item.quantity).toLocaleString('vi-VN') %>d</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p style="color: #666;">Khong co mon dang dat</p>
      <% } %>
    </div>

    <!-- Invoice Summary -->
    <div style="margin-bottom: 20px; padding: 16px; background: linear-gradient(135deg, #fff9e6 0%, #fff0cc 100%); border: 2px solid #8B6F47; border-radius: 8px;">
      <h3 style="margin: 0 0 16px 0; color: #3e3328; border-bottom: 2px solid #8B6F47; padding-bottom: 8px;">HOA DON CHI TIET</h3>
      
      <table style="width: 100%; margin-bottom: 12px;">
        <tr style="border-bottom: 1px solid #ddd;">
          <td style="padding: 8px; text-align: left;">Tien Coc Ban (Deposit):</td>
          <td style="padding: 8px; text-align: right; font-weight: 500;"><%= (reservation.depositAmount || 0).toLocaleString('vi-VN') %>đ</td>
        </tr>
        <% if (reservation.orderItems && reservation.orderItems.length > 0) { %>
          <tr style="background: #f5f5f5;">
            <td colspan="2" style="padding: 8px; font-weight: 600; color: #3e3328;">Mon An Dat Truoc:</td>
          </tr>
          <% let subtotal = 0; %>
          <% reservation.orderItems.forEach(item => { 
            const itemTotal = (item.price || 0) * (item.quantity || 0);
            subtotal += itemTotal;
          %>
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 8px; padding-left: 24px;">
                <%= item.dishId?.name || item.name || '-' %> (x<%= item.quantity %>)
              </td>
              <td style="padding: 8px; text-align: right;">
                <%= itemTotal.toLocaleString('vi-VN') %>đ
              </td>
            </tr>
          <% }); %>
          <tr style="border-bottom: 1px solid #ddd; font-weight: 600;">
            <td style="padding: 8px; text-align: right; padding-right: 12px;">Subtotal Mon An:</td>
            <td style="padding: 8px; text-align: right;"><%= subtotal.toLocaleString('vi-VN') %>đ</td>
          </tr>
          <% if (reservation.foodDiscount > 0) { %>
            <tr style="border-bottom: 1px solid #ddd; color: #d32f2f;">
              <td style="padding: 8px; text-align: right; padding-right: 12px;">Khuyen Mai / Giam Gia:</td>
              <td style="padding: 8px; text-align: right; font-weight: 600;">-<%= (reservation.foodDiscount || 0).toLocaleString('vi-VN') %>đ</td>
            </tr>
          <% } %>
          <tr style="border-bottom: 2px solid #8B6F47; background: #fff5e6;">
            <td style="padding: 12px; font-weight: 600; color: #3e3328;">TONG TIEN HOA DON:</td>
            <td style="padding: 12px; text-align: right; font-size: 1.3em; font-weight: 700; color: #8B6F47;">
              <%= (reservation.totalAmount || 0).toLocaleString('vi-VN') %>đ
            </td>
          </tr>
        <% } else { %>
          <tr style="border-bottom: 2px solid #8B6F47; background: #fff5e6;">
            <td style="padding: 12px; font-weight: 600; color: #3e3328;">TONG TIEN HOA DON:</td>
            <td style="padding: 12px; text-align: right; font-size: 1.3em; font-weight: 700; color: #8B6F47;">
              <%= (reservation.totalAmount || 0).toLocaleString('vi-VN') %>đ
            </td>
          </tr>
        <% } %>
      </table>

      <!-- Payment Status -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding: 12px; background: white; border-radius: 4px;">
        <div>
          <strong>Trang Thai Thanh Toan:</strong>
          <span style="margin-left: 8px; padding: 4px 12px; border-radius: 4px; font-weight: 600;
            <% if (reservation.paymentStatus === 'paid') { %>
              background: #d4edda; color: #155724;
            <% } else { %>
              background: #fff3cd; color: #856404;
            <% } %>">
            <%= reservation.paymentStatus === 'paid' ? '✓ DA THANH TOAN' : '○ CHUA THANH TOAN' %>
          </span>
        </div>
        <% if (reservation.paidAt) { %>
          <div style="font-size: 0.9em; color: #666;">
            Thanh toan luc: <%= new Date(reservation.paidAt).toLocaleString('vi-VN') %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Status & Actions -->
    <div style="border-top: 1px solid #ddd; padding-top: 20px;">
      <h3 style="margin: 0 0 12px 0; color: #3e3328;">Trang Thai Dat Ban</h3>
      <p style="margin: 8px 0;">
        <strong>Trang Thai Hien Tai:</strong>
        <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.9em;
          <% if (reservation.status === 'pending') { %>
            background: #fff3cd; color: #856404;
          <% } else if (reservation.status === 'confirmed' || reservation.status === 'paid' || reservation.status === 'processing') { %>
            background: #d1ecf1; color: #0c5460;
          <% } else if (reservation.status === 'completed') { %>
            background: #d4edda; color: #155724;
          <% } %>
        ">
          <%= reservation.status === 'pending' ? 'Cho xac nhan' : 
              reservation.status === 'confirmed' ? 'Da xac nhan' :
              reservation.status === 'paid' ? 'Da thanh toan' :
              reservation.status === 'processing' ? 'Dang xu ly' :
              reservation.status === 'completed' ? 'Hoan thanh' : reservation.status %>
        </span>
      </p>

      <!-- Confirm Reservation (only if pending) -->
      <% if (reservation.status === 'pending') { %>
        <div style="margin-top: 20px; padding: 12px; background: #e7f3ff; border-radius: 4px;">
          <p style="margin-bottom: 12px; color: #0c5460;">Xac nhan dat ban nay se cap nhat trang thai va tao hoa don thanh toan.</p>
          <form method="POST" action="/reception/reservations/<%= reservation._id %>/confirm" onsubmit="return confirm('Ban chac chan muon xac nhan dat ban nay?');">
            <input type="hidden" name="confirmCode" value="CONFIRMED">
            <button type="submit" style="padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 500;">
              Xac Nhan Dat Ban
            </button>
          </form>
        </div>
      <% } else { %>
        <p style="color: #666; margin-top: 12px;">Dat ban da duoc xac nhan. Khong the thay doi trang thai.</p>
      <% } %>
    </div>
  </div>
</div>
